# ══════════════════════════════════════════════════════════════
# GrindVacPro — .gitignore
# ══════════════════════════════════════════════════════════════

# ── Python ──────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg
.eggs/

# ── Виртуальные окружения ───────────────────────────────────────
.venv/
venv/
env/

# ── IDE / Editor ────────────────────────────────────────────────
.vscode/
.idea/
.kilo/
*.swp
*.swo
*~

# ── Окружение ───────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Docker volumes / runtime ────────────────────────────────────
*.pid
*.seed

# ── OS ──────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Логи ────────────────────────────────────────────────────────
*.log
logs/

# ── Тесты / покрытие ────────────────────────────────────────────
.pytest_cache/
htmlcov/
.coverage
coverage.xml


# ── Технические MD ──────────────────────────────────────────────
AGENTS.md
CONTEXT.md